NEXT_PUBLIC_APP_URL=http://localhost:3000

# AES-256-GCM encryption key for files stored in R2 (64-char hex)
STORAGE_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# CockroachDB Serverless
DATABASE_URL=postgresql://USER:PASS@HOST:26257/defaultdb?sslmode=verify-full

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=dashboard-unilever

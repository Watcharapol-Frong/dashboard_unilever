NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Dev / Ops Flags ────────────────────────────────────────────────────────

# Dev Mode: bypass Clerk auth entirely (development only — no effect in production)
# Both vars must be set together. NEXT_PUBLIC_ exposes the flag to the browser.
# DEV_MODE=true
# NEXT_PUBLIC_DEV_MODE=true

# Maintenance Mode: redirect all visitors to /maintenance page
# Set in Vercel environment variables to activate
# MAINTENANCE_MODE=true

# ─── Clerk Auth (https://dashboard.clerk.com) ───────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

# ─── Invite Codes for User Registration ─────────────────────────────────────
# Role is set in Clerk publicMetadata via clerkClient.users.createUser
# admin → full access · viewer → read-only dashboard
INVITE_CODE_VIEWER=your-viewer-invite-code
INVITE_CODE_ADMIN=your-admin-invite-code

# ─── Google Apps Script Ingest ───────────────────────────────────────────────
# Shared secret for GAS → /api/data/ingest/* (generate a random string, 32+ chars)
INGEST_API_SECRET=your-random-secret-here

# ─── File Storage Encryption ─────────────────────────────────────────────────
# AES-256-GCM key for files stored in R2 (must be exactly 64 hex chars)
# Generate: openssl rand -hex 32
STORAGE_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# ─── CockroachDB Serverless ──────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST:26257/defaultdb?sslmode=verify-full

# ─── Cloudflare R2 (S3-compatible) ───────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=dashboard-unilever

# ─── Dify AI Assistant (https://dify.ai) ─────────────────────────────────────
DIFY_API_KEY=your-dify-api-key
NEXT_PUBLIC_DIFY_API_URL=https://api.dify.ai/v1
NEXT_PUBLIC_DIFY_TOKEN=your-dify-public-token

# ─── Mart Build (optional) ───────────────────────────────────────────────────
# Attribution window in days — orders within this window of first_connected_date
# count as converted. Default: 14. Used by npm run build-mart and GitHub Actions.
# ATTRIBUTION_DAYS=14
